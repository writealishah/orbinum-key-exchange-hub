generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model DisclosureKey {
  id             String    @id @default(uuid())
  owner_address  String    // Lowercase EVM address of submitter
  disclosure_key String    @db.Text // Full orbdisc:... key string
  status         String    // "AVAILABLE", "CLAIMED", "EXPIRED"
  claimed_by     String?   // Lowercase EVM address of claimer
  claimed_at     DateTime?
  created_at     DateTime  @default(now())

  @@index([status, owner_address])
  @@index([owner_address])
  @@map("disclosure_keys")
}

model RateLimit {
  id           String   @id @default(uuid())
  user_address String   // Lowercase EVM address
  action_date  String   // YYYY-MM-DD format
  count        Int      @default(1)
  updated_at   DateTime @updatedAt

  @@unique([user_address, action_date])
  @@map("rate_limits")
}
